{
  "name": "@gubbi/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Gubbi — Terminal-native Git + GitHub client monorepo",
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*", "app/*"],
  "scripts": {
    "dev": "turbo run dev",
    "dev:cli": "turbo run dev --filter @gubbi/cli",
    "dev:web": "turbo run dev --filter @gubbi/web",
    "build": "turbo run build",
    "build:cli": "turbo run build --filter @gubbi/cli",
    "build:web": "turbo run build --filter @gubbi/web",
    "lint": "turbo run lint",
    "format": "oxfmt .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
