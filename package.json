{
	"name": "gubbi",
	"version": "0.1.0",
	"private": true,
	"description": "Terminal-native Git + GitHub client — an enhanced alternative to the GitHub web UI",
	"bin": {
		"gubbi": "./src/index.tsx"
	},
	"type": "module",
	"module": "src/index.tsx",
	"scripts": {
		"dev": "bun --hot src/index.tsx",
		"start": "bun src/index.tsx",
		"test": "bun test",
		"lint": "oxlint .",
		"format": "oxfmt .",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@opentui/core": "0.1.88",
		"@opentui/solid": "0.1.88",
		"solid-js": "1.9.11"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"lefthook": "^2.1.4",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"typescript": "^5.9.3"
	}
}
